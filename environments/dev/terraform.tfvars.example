aws_region = "ap-southeast-2"

allowed_account_ids = [
    "123456789012"
]

project_name = "core-infrastructure"
environment  = "dev"
cost_center  = "platform-engineering"
owner        = "platform-team"

vpc_cidr = "10.10.0.0/16"

availability_zones = [
    "ap-southeast-2a",
    "ap-southeast-2b"
]

public_subnet_cidrs = [
    "10.10.0.0/24",
    "10.10.1.0/24"
]

private_subnet_cidrs = [
    "10.10.10.0/24",
    "10.10.11.0/24"
]

enable_nat_gateway = false
single_nat_gateway = true

instance_type   = "t3.micro"
instance_volume_size    = 8

notification_email = "replace-me@example.com"
monthly_budget_limit = "25"